{
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    },
    {
      "files": "apps/web/**/*.{ts,svelte}",
      "options": {
        "tailwindStylesheet": "./apps/web/src/app.css"
      }
    },
    {
      "files": "packages/ui/**/*.{ts,svelte}",
      "options": {
        "tailwindStylesheet": "./packages/ui/src/app.css"
      }
    }
  ]
}
